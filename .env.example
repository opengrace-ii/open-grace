# Open Grace Environment Configuration
# Copy this file to .env and update the values

# ============================================
# API Configuration
# ============================================
# API server host and port
GRACE_API_HOST=0.0.0.0
GRACE_API_PORT=8000

# Secret key for JWT token generation (change in production!)
GRACE_SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================
# Frontend Configuration
# ============================================
# URL for the backend API
VITE_API_URL=http://localhost:8000

# ============================================
# Ollama Configuration
# ============================================
# Ollama server URL
OLLAMA_URL=http://localhost:11434

# Default model to use
OLLAMA_DEFAULT_MODEL=llama3.2

# ============================================
# Database Configuration
# ============================================
# SQLite database path
GRACE_DB_PATH=./data/grace.db

# Vector store path
GRACE_VECTOR_STORE_PATH=./data/vector_store

# ============================================
# Security Configuration
# ============================================
# Enable/disable Docker sandbox (NEVER disable in production!)
GRACE_SANDBOX_ENABLED=true

# Vault encryption key (generate with: openssl rand -hex 32)
GRACE_VAULT_KEY=

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
GRACE_LOG_LEVEL=INFO

# Log file path (optional)
# GRACE_LOG_FILE=./logs/grace.log

# ============================================
# Plugin Configuration
# ============================================
# Plugin directory
GRACE_PLUGIN_DIR=./plugins

# Allow unsigned plugins (set to false in production)
GRACE_ALLOW_UNSIGNED_PLUGINS=false

# ============================================
# Advanced Configuration
# ============================================
# Maximum concurrent tasks
GRACE_MAX_CONCURRENT_TASKS=10

# Task timeout in seconds
GRACE_TASK_TIMEOUT=3600

# Enable WebSocket for real-time updates
GRACE_ENABLE_WEBSOCKET=true